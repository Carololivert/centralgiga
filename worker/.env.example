# ── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# ⚠️ SERVICE ROLE key (Settings → API → service_role). NUNCA no frontend!
SUPABASE_SERVICE_ROLE_KEY=eyJ...SERVICE_ROLE...
RESULT_BUCKET=resultados

# ── SGP: API oficial (Token/App) ───────────────────────────────
# Usada por Relatório de OS, Termos Agendados e Verificar Vendas (consulta de
# cliente). NÃO passa pelo login web → NÃO depende de 2FA.
SGP_BASE=https://giganetwireless.sgp.net.br
SGP_TOKEN=
SGP_APP=

# ── SGP: login web (só p/ o que a API não cobre) ───────────────
# Usado por Conferência de Checklist, Linhas Canceladas e Remover Linhas
# (raspagem da área /admin). Se o SGP exigir 2FA no login, ver SGP_2FA_SECRET.
SGP_USER=seu_usuario
SGP_PASS=sua_senha
SGP_VERIFY_SSL=false
# Segredo do app autenticador (TOTP) p/ o 2FA automático em comum/sgp_login.py:
SGP_2FA_SECRET=
# Alternativa: SGP_2FA_MANUAL=true  (digitar o código na mão — não serve no worker)

# ── FocusChat: API oficial (Token do Canal) ────────────────────
# Usada por Verificar Vendas (lista os atendimentos de VENDAS).
FOCUS_TOKEN=
# Legado (só scripts antigos que raspam o painel; o worker não usa):
# FOCUS_USER=
# FOCUS_PASS=

# ── Worker ─────────────────────────────────────────────────────
WORKER_POLL_SECONDS=5
