# ── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_KEY=eyJ...ANON_KEY...
# service_role — só nas server routes de admin (criar/editar usuário). Nunca vai pro navegador.
SUPABASE_SERVICE_KEY=eyJ...SERVICE_ROLE...

# ── Giganet Avaliações (server-side, usado só nas API routes) ───
# Mesmo valor de app_secrets.giganet_webhook_secret (migration 0006)
GIGANET_WEBHOOK_SECRET=troque-esse-segredo
# Webhook do n8n que publica a resposta no Google
N8N_PUBLICAR_URL=https://n8n.seu-dominio.com/webhook/publicar-avaliacao
# IA para regerar respostas (botão "regerar com IA")
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Opcional: servidor Flask Aut-SGP (legado / health-check) ───
NUXT_PUBLIC_SGP_URL=http://localhost:5000

# ── Monitor SmartOLT: API embarcada no worker (../worker) ──────
# As rotas server/api/monitor/* fazem proxy pra cá (só admin/supervisor).
# Mesmo host do worker → http://127.0.0.1:5001. Se o worker estiver em OUTRO
# host (ex.: web na Vercel, worker no VPS), use o endereço do worker e defina
# o MONITOR_API_TOKEN igual ao do worker/.env.
MONITOR_API_URL=http://127.0.0.1:5001
# MONITOR_API_TOKEN=
